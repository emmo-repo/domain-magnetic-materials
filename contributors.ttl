<https://w3id.org/emmo/domain/magnetic-materials/contributors> rdf:type owl:Ontology ;
    owl:versionIRI <https://w3id.org/emmo/domain/magnetic-materials/0.0.6/contributors> ;
    dcterms:abstract "People and organisations who has contributed to the development of the magnetic materials domain ontology."@en ;
